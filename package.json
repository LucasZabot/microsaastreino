{
  "name": "workout-app-backend",
  "version": "1.0.0",
  "description": "Backend completo para app de treinos com autenticação JWT, CRUD, pagamentos e IA",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "jest --watchAll",
    "setup": "node scripts/setup-database.js",
    "migration:create": "npx sequelize-cli migration:create --name",
    "migration:run": "npx sequelize-cli db:migrate",
    "migration:rollback": "npx sequelize-cli db:migrate:undo",
    "seed:create": "npx sequelize-cli seed:generate --name",
    "seed:run": "npx sequelize-cli db:seed:all"
  },
  "dependencies": {
    "express": "^4.18.2",
    "express-validator": "^7.0.1",
    "express-rate-limit": "^6.7.0",
    "helmet": "^7.0.0",
    "cors": "^2.8.5",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.0",
    "sequelize": "^6.32.0",
    "pg": "^8.11.0",
    "pg-hstore": "^2.3.4",
    "dotenv": "^16.0.3",
    "morgan": "^1.10.0",
    "stripe": "^12.9.0",
    "nodemailer": "^6.9.3",
    "uuid": "^9.0.0",
    "multer": "^1.4.5-lts.1",
    "joi": "^17.9.2",
    "swagger-ui-express": "^4.6.3",
    "swagger-jsdoc": "^6.2.8",
    "ml-matrix": "^6.10.7",
    "node-cron": "^3.0.2",
    "winston": "^3.8.2"
  },
  "devDependencies": {
    "nodemon": "^2.0.22",
    "jest": "^29.5.0",
    "supertest": "^6.3.3",
    "sequelize-cli": "^6.6.1"
  },
  "keywords": [
    "nodejs",
    "express",
    "postgresql",
    "jwt",
    "stripe",
    "ai",
    "workout",
    "fitness"
  ],
  "author": "Workout App Team",
  "license": "MIT"
}